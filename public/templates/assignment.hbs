<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8" />

  <title>Assignment</title>

  <style>
    body {
      font-family: Arial, sans-serif;
      padding: 40px;
      color: #222;
      line-height: 1.6;
    }

    .header {
      text-align: center;
      margin-bottom: 30px;
    }

    .meta {
      display: flex;
      justify-content: space-between;
      margin-bottom: 20px;
    }

    .section {
      margin-top: 40px;
    }

    .question {
      margin-bottom: 20px;
    }

    .difficulty {
      color: gray;
      font-size: 14px;
    }

    ul {
      margin-top: 8px;
    }
  </style>
</head>

<body>

  <div class="header">
    <h1>{{assignment.schoolName}}</h1>

    <h2>Subject: {{assignment.subject}}</h2>

    <h3>Class: {{assignment.className}}</h3>
  </div>

  <div class="meta">
    <div>Duration: {{assignment.duration}}</div>

    <div>Maximum Marks: {{assignment.maximumMarks}}</div>
  </div>

  {{#each assignment.sections}}

    <div class="section">

      <h2>{{title}}</h2>

      <p>{{instructions}}</p>

      <ol>

        {{#each questions}}

          <li class="question">

            <div>
              <strong>{{question}}</strong>
            </div>

            <div>
              Marks: {{marks}}
            </div>

            <div class="difficulty">
              Difficulty: {{difficulty}}
            </div>

            {{#if options.length}}

              <ul>

                {{#each options}}
                  <li>{{this}}</li>
                {{/each}}

              </ul>

            {{/if}}

          </li>

        {{/each}}

      </ol>

    </div>

  {{/each}}

</body>

</html>